    <!-- 2026-06-03: lean replacement for the historical broken flybase-alleles source.
         Loads description + supporting FBrf publications from the 21-col FB2026_01
         precomputed file, merges by FBal into chado-loaded Allele rows. Other 21-col
         fields (insertion details, alleleClass FBcv multi-values, encoded product,
         tagged with, "also carries") are deferred to v2. -->
    <source name="flybase-allele-descriptions" type="flybase-allele-descriptions" version="4.2.0">
      <property name="src.data.dir" location="/root/data/flybase/alleles/current"/>
      <property name="src.data.dir.includes" value="dmel_classical_and_insertion_allele_descriptions*.tsv"/>
    </source>

    <!-- 2026-06-04: canonical FBal -> FBgn mapping. The FB2026_01 precomputed file has
         305K FBals; chado-loaded Dmel feature table has only 239K. The ~66K delta is
         transgene-vector alleles (Ecol\lacZ, Scer\GAL4, Avic\GFP, Hsap\* fusions) which
         in chado are tagged with their source organism, not Dmel — chado's organism
         filter drops them. This source loads ALL FBals; loader merges by
         Allele.primaryIdentifier so existing chado items are no-ops and missing FBals
         become new stubs. See FLYMINE_PHASE2_FINDINGS_HANDOFF_2026_06_04 §3 + §4. -->
    <source name="flybase-allele-stubs" type="flybase-allele-stubs" version="4.2.0">
      <property name="src.data.dir" location="/root/data/flybase/alleles/aux/current"/>
      <property name="src.data.dir.includes" value="fbal_to_fbgn_*.tsv"/>
    </source>

